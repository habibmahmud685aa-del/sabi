# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Ключ OpenAI (получить на platform.openai.com)
OPENAI_API_KEY=sk-...

# Секретный ключ Flask (любая случайная строка, например из: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=замени-на-случайную-строку

# Среда запуска (development или production)
FLASK_ENV=production
